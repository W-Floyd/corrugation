{
  "name": "corrugation-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "build-dev": "vite build --mode development",
    "build-dev-watch": "vite build --mode development --watch",
    "format": "prettier --write \"src/**/*.{vue,ts,js,html}\"",
    "type-check": "vue-tsc --build",
    "prepare": "cd .. && git config core.hooksPath frontend/.husky"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@primeuix/themes": "^2.0.3",
    "pinia": "^3.0.4",
    "primevue": "^4.5.5",
    "vue": "^3.5.32",
    "vue-material-design-icons": "^5.3.1",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/css": "^1.2.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.8",
    "vite-plugin-favicon-generator": "^1.0.2",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "lint-staged": {
    "*.{vue,ts,js,html}": "prettier --write"
  }
}
